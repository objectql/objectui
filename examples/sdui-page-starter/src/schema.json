{
  "type": "page",
  "title": "Customer Operations",
  "description": "Schema-driven page example for third-party projects",
  "children": [
    {
      "type": "grid",
      "cols": { "base": 1, "md": 3 },
      "gap": 4,
      "children": [
        {
          "type": "statistic",
          "label": "Active Customers",
          "value": "1,284",
          "description": "+12% from last month",
          "trend": "up"
        },
        {
          "type": "statistic",
          "label": "Monthly Revenue",
          "value": "$96,430",
          "description": "+8.3% from last month",
          "trend": "up"
        },
        {
          "type": "statistic",
          "label": "Conversion Rate",
          "value": "4.2%",
          "description": "Qualified lead to customer",
          "trend": "up"
        }
      ]
    },
    {
      "type": "separator",
      "className": "my-6"
    },
    {
      "type": "card",
      "title": "Recent Orders",
      "description": "Latest sales orders across all regions",
      "children": [
        {
          "type": "data-table",
          "columns": [
            { "header": "Order", "accessorKey": "id" },
            { "header": "Customer", "accessorKey": "customer" },
            { "header": "Total", "accessorKey": "total" },
            { "header": "Status", "accessorKey": "status" }
          ],
          "data": [
            { "id": "SO-1042", "customer": "Northwind Labs", "total": "$3,420", "status": "Paid" },
            { "id": "SO-1043", "customer": "Pioneer Retail", "total": "$1,180", "status": "Pending" },
            { "id": "SO-1044", "customer": "Vertex Co", "total": "$5,090", "status": "Shipped" }
          ]
        }
      ]
    },
    {
      "type": "grid",
      "cols": { "base": 1, "md": 2 },
      "gap": 4,
      "className": "mt-6",
      "children": [
        {
          "type": "button",
          "content": "Create Customer",
          "variant": "default"
        },
        {
          "type": "button",
          "content": "Admin Settings",
          "variant": "outline",
          "hidden": "${data.user.role !== 'admin'}"
        }
      ]
    }
  ]
}
