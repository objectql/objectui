{
  "name": "@object-ui/core",
  "version": "3.3.0",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "description": "Core logic, types, and validation for Object UI. Zero React dependencies.",
  "homepage": "https://www.objectui.org/docs/core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/objectstack-ai/objectui.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/objectstack-ai/objectui/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@object-ui/types": "workspace:*",
    "@objectstack/spec": "^4.0.3",
    "lodash": "^4.18.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "objectui",
    "sdui",
    "schema-driven-ui",
    "react",
    "tailwind",
    "shadcn",
    "objectstack",
    "core",
    "engine",
    "expression-engine",
    "action-engine",
    "registry"
  ],
  "author": "ObjectStack Team <team@objectstack.ai>",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
