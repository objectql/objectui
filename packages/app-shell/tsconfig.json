{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM"],
    "types": ["node", "vite/client"],
    "noEmit": false,
    "declaration": true,
    "composite": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"],
  "references": [
    { "path": "../types" },
    { "path": "../core" },
    { "path": "../react" },
    { "path": "../components" },
    { "path": "../auth" },
    { "path": "../data-objectstack" }
  ]
}
