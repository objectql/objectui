    "type-check": "tsc --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@object-ui/types": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "react": "19.2.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "objectui",
    "sdui",
    "schema-driven-ui",
    "react",
    "tailwind",
    "shadcn",
    "objectstack",
