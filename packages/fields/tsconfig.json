{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM"],
    "noEmit": false,
    "declaration": true,
    "composite": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  "references": [
    {
      "path": "../components"
    },
    {
      "path": "../core"
    },
    {
      "path": "../i18n"
    },
    {
      "path": "../react"
    },
    {
      "path": "../types"
    }
  ]
}
